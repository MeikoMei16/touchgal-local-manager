{
  "name": "touchgal-local-manager",
  "private": true,
  "version": "0.1.1",
  "description": "Desktop TouchGal local manager for browsing, favoriting, downloading, extracting, and launching games.",
  "author": "Meiko Mei",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "clean": "node -e \"const fs=require('fs');['out','dist','release'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "clean:all": "pnpm clean && rm -rf node_modules pnpm-lock.yaml ~/.cache/electron ~/.config/touchgal-local-manager/touchgal.db",
    "rebuild": "electron-rebuild",
    "rebuild:all": "pnpm clean:all && pnpm install",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.4.3",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "7.1.0-canary-9627b5a1-20260327",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1"
  }
}
